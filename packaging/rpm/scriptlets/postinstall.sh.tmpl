#!/bin/sh
# postinstall — generate env file with random DB password on first install.
# SERVICE_NAME, BINARY_NAME, DB_NAME, APP_USER, PORT are substituted at build time.
set -e

SVC="__SERVICE_NAME__"
ETC_DIR="/etc/duynhlab/${SVC}"
ENV_FILE="${ETC_DIR}/${SVC}.env"
TEMPLATE="${ETC_DIR}/${SVC}.env.template"

mkdir -p "${ETC_DIR}"

if [ ! -f "${ENV_FILE}" ]; then
  PASS="$(/usr/bin/duynhlab-gen-password 32 2>/dev/null || \
          tr -dc 'A-Za-z0-9' </dev/urandom | head -c 32)"

  cat > "${ENV_FILE}" <<EOF
# /etc/duynhlab/${SVC}/${SVC}.env — generated by RPM postinstall
# Override per-host values in ${SVC}.override (also auto-loaded).

SERVICE_NAME=${SVC}
PORT=__PORT__

DB_HOST=localhost
DB_PORT=5432
DB_NAME=__DB_NAME__
DB_USER=__APP_USER__
DB_PASSWORD=${PASS}
DB_SSLMODE=disable
DB_POOL_MAX_CONNECTIONS=25

DB_MIGRATOR_USER=__APP_USER___migrator
DB_MIGRATOR_PASSWORD=${PASS}
EOF
  chown root:duynhlab "${ENV_FILE}"
  chmod 0640 "${ENV_FILE}"

  echo ""
  echo "================================================================"
  echo "  duynhlab-${SVC} installed."
  echo "  Generated DB credentials -> ${ENV_FILE}"
  echo ""
  echo "  Next steps (as root):"
  echo "    SUPERUSER_DSN=postgresql://postgres:secret@localhost:5432/postgres \\"
  echo "      duynhlab-db-setup bootstrap ${SVC}"
  echo "    duynhlab-db-setup migrate ${SVC}"
  echo "    systemctl enable --now duynhlab-${SVC}"
  echo "================================================================"
else
  echo "Existing env file preserved: ${ENV_FILE}"
fi

# Ship template alongside so admins can diff after upgrades.
if [ ! -f "${TEMPLATE}" ]; then
  sed 's/^DB_PASSWORD=.*/DB_PASSWORD=__GENERATED_AT_INSTALL__/' \
    "${ENV_FILE}" > "${TEMPLATE}"
  chmod 0644 "${TEMPLATE}"
fi

systemctl daemon-reload >/dev/null 2>&1 || :

exit 0
