#!/bin/sh
# postremove — daemon-reload; keep env file and database for re-install.
set -e
systemctl daemon-reload >/dev/null 2>&1 || :

if [ "$1" = "0" ] || [ "$1" = "purge" ]; then
  echo "duynhlab-__SERVICE_NAME__ removed. Env file and database were preserved."
  echo "To wipe completely:"
  echo "  rm -rf /etc/duynhlab/__SERVICE_NAME__"
  echo "  psql -U postgres -c 'DROP DATABASE __DB_NAME__;'"
fi
exit 0
