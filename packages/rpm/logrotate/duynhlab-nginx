# /etc/logrotate.d/duynhlab-nginx
# Rotate nginx access/error logs scoped to the duynhlab vhost.

/var/log/duynhlab/nginx/*.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    create 0640 nginx adm
    sharedscripts
    postrotate
        if [ -f /var/run/nginx.pid ]; then
            /bin/kill -USR1 "$(cat /var/run/nginx.pid)" 2>/dev/null || true
        fi
    endscript
}
