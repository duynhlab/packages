#!/usr/bin/env bash
# duynhdb — manage per-service PostgreSQL databases on duynhlab hosts.
#
# Subcommands:
#   bootstrap <svc>   CREATE DATABASE + CREATE USER + GRANT (needs SUPERUSER_DSN)
#   migrate   <svc>   Run pending migrations by exec'ing the service binary's own
#                     `migrate` subcommand (golang-migrate embedded via pkg/migratex)
#   status    <svc>   Print installed schema_migrations version vs shipped SCHEMA_VERSION
#
# Migrations are forward-only and embedded in each service binary (//go:embed) — this
# repo ships no separate migrate tool and no loose SQL. See plan.md D23/D24.
#
# Env (read from /etc/duynhlab/<svc>.env):
#   DB_HOST DB_PORT DB_NAME DB_USER DB_PASSWORD DB_SSLMODE
#   DB_MIGRATOR_USER DB_MIGRATOR_PASSWORD (migrate/status run as the migrator role)
# Extra env for bootstrap:
#   SUPERUSER_DSN=postgresql://postgres:secret@host:5432/postgres  (remote DB)
#   — leave unset for a same-host DB: bootstrap uses local peer auth as `postgres`.

set -euo pipefail

PROG=${0##*/}
ETC_BASE=${ETC_BASE:-/etc/duynhlab}
OPT_BASE=${OPT_BASE:-/opt/duynhlab}

die() { echo "$PROG: error: $*" >&2; exit 1; }
info() { echo "$PROG: $*" >&2; }

usage() {
  cat >&2 <<EOF
Usage: $PROG <bootstrap|migrate|status> <service>

  bootstrap <svc>           Create database, app/migrator users, grant privileges.
                            SUPERUSER_DSN for a remote DB; unset = local peer auth
                            as the postgres OS user (same-host PostgreSQL).
  migrate   <svc>           Apply outstanding migrations via the service binary
                            (\`<binary> migrate\`, as the migrator user).
  status    <svc>           Show installed schema_migrations version vs shipped
                            SCHEMA_VERSION (forward-only; no rollback).

Service env file: \$ETC_BASE/<svc>.env (default $ETC_BASE)
EOF
  exit 2
}

[[ $# -ge 2 ]] || usage
CMD=$1; SVC=$2; shift 2 || true

ENV_FILE="$ETC_BASE/$SVC.env"
BIN_DIR="$OPT_BASE/$SVC/bin"
SCHEMA_VERSION_FILE="$OPT_BASE/$SVC/SCHEMA_VERSION"

[[ -f "$ENV_FILE" ]] || die "Env file missing: $ENV_FILE"

# shellcheck disable=SC1090
set -a; . "$ENV_FILE"; set +a

: "${DB_HOST:?DB_HOST not set in $ENV_FILE}"
: "${DB_PORT:?DB_PORT not set in $ENV_FILE}"
: "${DB_NAME:?DB_NAME not set in $ENV_FILE}"
: "${DB_USER:?DB_USER not set in $ENV_FILE}"
: "${DB_PASSWORD:?DB_PASSWORD not set/empty in $ENV_FILE — refuse to proceed}"
: "${DB_SSLMODE:=disable}"

[[ -n "$DB_PASSWORD" ]] || die "DB_PASSWORD is empty in $ENV_FILE"

APP_USER=${DB_USER}
MIGRATOR_USER=${DB_MIGRATOR_USER:-${DB_USER}_migrator}
MIGRATOR_PASSWORD=${DB_MIGRATOR_PASSWORD:-$DB_PASSWORD}

build_dsn() {
  local user=$1 pass=$2
  printf "postgresql://%s:%s@%s:%s/%s?sslmode=%s" \
    "$user" "$pass" "$DB_HOST" "$DB_PORT" "$DB_NAME" "$DB_SSLMODE"
}

require_psql() { command -v psql >/dev/null 2>&1 || die "psql not found (install postgresql client)"; }

# Resolve the single service binary under /opt/duynhlab/<svc>/bin/.
service_binary() {
  local bin
  bin=$(find "$BIN_DIR" -maxdepth 1 -type f -perm -u+x 2>/dev/null | head -1)
  [[ -n "$bin" ]] || die "No executable found in $BIN_DIR"
  printf '%s\n' "$bin"
}

case "$CMD" in
  bootstrap)
    require_psql
    # Superuser step: explicit SUPERUSER_DSN (remote/managed DB), or — when unset
    # — local peer auth as the postgres OS user for a same-host PostgreSQL.
    if [[ -n "${SUPERUSER_DSN:-}" ]]; then
      su_psql=(psql "$SUPERUSER_DSN")
      info "Bootstrapping database $DB_NAME on $DB_HOST:$DB_PORT (SUPERUSER_DSN)"
    else
      command -v runuser >/dev/null 2>&1 \
        || die "SUPERUSER_DSN unset and runuser not found (need it for local peer auth)"
      su_psql=(runuser -u postgres -- psql)
      info "Bootstrapping database $DB_NAME via local peer auth (postgres OS user)"
    fi
    "${su_psql[@]}" -v ON_ERROR_STOP=1 <<SQL
DO \$\$
BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '$APP_USER') THEN
    CREATE ROLE "$APP_USER" LOGIN PASSWORD '$DB_PASSWORD';
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '$MIGRATOR_USER') THEN
    CREATE ROLE "$MIGRATOR_USER" LOGIN PASSWORD '$MIGRATOR_PASSWORD';
  END IF;
END
\$\$;
SELECT 'CREATE DATABASE "$DB_NAME" OWNER "$MIGRATOR_USER"'
 WHERE NOT EXISTS (SELECT FROM pg_database WHERE datname = '$DB_NAME')\gexec
GRANT CONNECT ON DATABASE "$DB_NAME" TO "$APP_USER";
SQL
    psql "$(build_dsn "$MIGRATOR_USER" "$MIGRATOR_PASSWORD")" -v ON_ERROR_STOP=1 <<SQL
GRANT USAGE ON SCHEMA public TO "$APP_USER";
ALTER DEFAULT PRIVILEGES IN SCHEMA public
  GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO "$APP_USER";
ALTER DEFAULT PRIVILEGES IN SCHEMA public
  GRANT USAGE, SELECT ON SEQUENCES TO "$APP_USER";
SQL
    info "Bootstrap OK (db=$DB_NAME, app=$APP_USER, migrator=$MIGRATOR_USER)"
    ;;

  migrate)
    BIN=$(service_binary)
    info "Applying embedded migrations: $BIN migrate (as $MIGRATOR_USER, direct host $DB_HOST)"
    # The binary builds its DSN from DB_* env. Run as the migrator role against the
    # DIRECT host (DDL via a pooler is unsafe — migratex forbids it). DB_HOST in the
    # env file points at the real Postgres on bare-metal, so no pooler is involved.
    DB_USER="$MIGRATOR_USER" DB_PASSWORD="$MIGRATOR_PASSWORD" "$BIN" migrate
    info "Migrations applied"
    ;;

  status)
    require_psql
    DSN=$(build_dsn "$MIGRATOR_USER" "$MIGRATOR_PASSWORD")
    SHIPPED=$(cat "$SCHEMA_VERSION_FILE" 2>/dev/null || echo "unknown")
    # golang-migrate tracks state in the unqualified `schema_migrations` table.
    INSTALLED=$(psql "$DSN" -tAc \
      "SELECT version || (CASE WHEN dirty THEN ' (DIRTY)' ELSE '' END) FROM schema_migrations" \
      2>/dev/null || echo "none")
    [[ -n "$INSTALLED" ]] || INSTALLED="none"
    echo "service:       $SVC"
    echo "shipped:       $SHIPPED   (max embedded migration, audit-only)"
    echo "installed:     $INSTALLED"
    ;;

  *)
    usage
    ;;
esac
