#!/usr/bin/env bash
# duynhctl — operational wrapper around systemctl/journalctl for duynhlab services.
#
# Commands:
#   list                        List all installed services
#   start    <svc|all>          Start service(s)
#   stop     <svc|all>          Stop service(s)
#   restart  <svc|all>          Restart service(s)
#   enable   <svc|all>          Enable on boot
#   disable  <svc|all>          Disable on boot
#   status   <svc|all>          Show systemd status
#   logs     <svc> [args...]    Tail journal for service (passes args to journalctl)
#   health   <svc|all>          curl /health on configured port
#   version  <svc|all>          Print binary + schema versions
#   config   <svc>              cat env file (masked password)
#   ports    [filter]           Show port assignments
#   support-bundle [dir]        Collect logs+configs for support (NO secrets)
set -euo pipefail

PROG=${0##*/}
OPT_BASE=${OPT_BASE:-/opt/duynhlab}
ETC_BASE=${ETC_BASE:-/etc/duynhlab}

if [[ -t 1 ]]; then
  C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'; C_GRN=$'\033[32m'; C_RED=$'\033[31m'; C_YEL=$'\033[33m'; C_RST=$'\033[0m'
else
  C_BOLD=; C_DIM=; C_GRN=; C_RED=; C_YEL=; C_RST=
fi

die() { echo "$PROG: $*" >&2; exit 1; }

# Service discovery is registry-free: enumerate the payload directories under
# /opt/duynhlab (a backend has bin/, the frontend has dist/) and read each
# service's PORT from its /etc/duynhlab/<svc>.env. No services.yaml, no yq.
list_services() {
  local d name
  for d in "$OPT_BASE"/*/; do
    name=$(basename "$d")
    case "$name" in
      etc|lib|nginx|valkey|postgresql|secret-tpl|logrotate) continue ;;
    esac
    [[ -d "$d/bin" || -d "$d/dist" ]] && echo "$name"
  done
}
svc_port() {
  # Returns 0 even when the env file is absent (e.g. frontend) — an empty port is
  # not an error. A bare `[[ -f ]] && …` would return 1 and abort callers' `set -e`.
  local f="$ETC_BASE/$1.env"
  [[ -f "$f" ]] || return 0
  sed -n 's/^PORT=//p' "$f" | head -1
}
svc_type() { [[ "$1" == "frontend" ]] && echo static || echo backend; }

resolve_targets() {
  if [[ "$1" == "all" ]]; then list_services; else echo "$1"; fi
}

unit_name() { echo "duynhlab-$1.service"; }

cmd_list() {
  printf "%-15s %-10s %-6s %-10s\n" "NAME" "TYPE" "PORT" "STATUS"
  while read -r svc; do
    local typ port stat
    typ=$(svc_type "$svc")
    port=$(svc_port "$svc")
    stat=$(systemctl is-active "$(unit_name "$svc")" 2>/dev/null || echo "n/a")
    case "$stat" in
      active) stat="${C_GRN}${stat}${C_RST}" ;;
      failed) stat="${C_RED}${stat}${C_RST}" ;;
      *) stat="${C_DIM}${stat}${C_RST}" ;;
    esac
    printf "%-15s %-10s %-6s %-21s\n" "$svc" "$typ" "$port" "$stat"
  done < <(list_services)
}

cmd_simple() {
  local action=$1 target=$2
  for svc in $(resolve_targets "$target"); do
    echo "${C_BOLD}==> systemctl $action $(unit_name "$svc")${C_RST}"
    systemctl "$action" "$(unit_name "$svc")"
  done
}

cmd_logs() {
  local svc=$1; shift || true
  exec journalctl -u "$(unit_name "$svc")" "$@"
}

cmd_health() {
  for svc in $(resolve_targets "$1"); do
    local port; port=$(svc_port "$svc")
    if [[ -z "$port" || "$port" == "null" ]]; then
      echo "$svc: ${C_DIM}no port configured${C_RST}"; continue
    fi
    local resp
    if resp=$(curl -fsS -m 3 "http://127.0.0.1:$port/health" 2>&1); then
      echo "$svc (:$port): ${C_GRN}OK${C_RST} ${C_DIM}${resp:0:60}${C_RST}"
    else
      echo "$svc (:$port): ${C_RED}FAIL${C_RST} ${C_DIM}${resp}${C_RST}"
    fi
  done
}

cmd_version() {
  for svc in $(resolve_targets "$1"); do
    local bin
    bin=$(cat "$OPT_BASE/$svc/BINARY_VERSION" 2>/dev/null || echo "unknown")
    printf "%-15s binary=%s\n" "$svc" "$bin"
  done
}

cmd_config() {
  local svc=$1
  local f="$ETC_BASE/$svc.env"
  [[ -f "$f" ]] || die "No env file: $f"
  sed 's/\(DB_PASSWORD=\).*/\1********/' "$f"
}

# Collect a diagnostics tarball for support. SECRETS ARE NEVER INCLUDED:
# <svc>.env and <svc>.override are excluded wholesale (they carry DB passwords).
cmd_support_bundle() {
  local outdir=${1:-/tmp}
  local version stamp work name
  version=$(sed -n 's/^DUYNHLAB_VERSION=//p' "$ETC_BASE/env-global.properties" 2>/dev/null | head -1)
  [ -n "$version" ] || version=unknown
  stamp=$(date -u +%Y%m%dT%H%M%SZ)
  name="duynhlab-support-${version}-${stamp}"
  work=$(mktemp -d)
  # Expand $work NOW — a deferred '$work' would be out of scope (set -u) at exit.
  trap "rm -rf '$work'" EXIT
  mkdir -p "$work/$name"/{journal,etc,opt}

  echo "Collecting (secrets are NOT included)..."
  # Per-service journal (last 7 days) + unit status.
  while read -r svc; do
    journalctl -u "duynhlab-$svc" --since '7 days ago' --no-pager \
      > "$work/$name/journal/duynhlab-$svc.log" 2>&1 || :
    systemctl status "duynhlab-$svc" --no-pager \
      > "$work/$name/journal/duynhlab-$svc.status" 2>&1 || :
  done < <(list_services)

  # Platform state.
  { cmd_list; echo; cmd_ports ""; } > "$work/$name/platform-state.txt" 2>&1 || :
  systemctl list-units 'duynhlab-*' --all --no-pager \
    > "$work/$name/units.txt" 2>&1 || :

  # Versions + composition (no secrets in any of these).
  cp -f "$OPT_BASE/etc/manifest"        "$work/$name/opt/manifest"        2>/dev/null || :
  cp -f /var/log/duynhlab/version.log   "$work/$name/install-history.log" 2>/dev/null || :
  for d in "$OPT_BASE"/*/BINARY_VERSION; do
    [ -f "$d" ] || continue
    printf '%s: %s\n' "$(basename "$(dirname "$d")")" "$(cat "$d")"
  done > "$work/$name/opt/binary-versions.txt" 2>/dev/null || :

  # Non-secret configs only. .env/.override are deliberately skipped.
  cp -f "$ETC_BASE/env-global.properties"  "$work/$name/etc/" 2>/dev/null || :
  cp -f /etc/nginx/conf.d/duynhlab.conf    "$work/$name/etc/" 2>/dev/null || :

  local out="$outdir/$name.tar.gz"
  tar -C "$work" -czf "$out" "$name"
  echo "${C_GRN}Support bundle: $out${C_RST}"
  echo "Secrets (*.env, *.override) are NOT included. Attach this file to your support request."
}

cmd_ports() {
  local filter=${1:-}
  {
    local p
    while read -r svc; do
      p=$(svc_port "$svc")
      printf '%s\t%s\t%s\n' "$svc" "${p:--}" "$(svc_type "$svc")"
    done < <(list_services)
  } | { [[ -n "$filter" ]] && grep -i "$filter" || cat; } \
    | column -t
}

usage() {
  sed -n '3,17p' "$0" | sed 's/^# \{0,1\}//'
  exit 2
}

CMD=${1:-}
[[ -n "$CMD" ]] || usage
shift || true

case "$CMD" in
  list)               cmd_list ;;
  start|stop|restart|enable|disable|status)
                      [[ $# -ge 1 ]] || die "usage: $PROG $CMD <svc|all>"
                      cmd_simple "$CMD" "$1" ;;
  logs)               [[ $# -ge 1 ]] || die "usage: $PROG logs <svc> [journalctl args]"
                      cmd_logs "$@" ;;
  health)             cmd_health "${1:-all}" ;;
  version)            cmd_version "${1:-all}" ;;
  config)             [[ $# -ge 1 ]] || die "usage: $PROG config <svc>"
                      cmd_config "$1" ;;
  ports)              cmd_ports "${1:-}" ;;
  support-bundle)     cmd_support_bundle "${1:-/tmp}" ;;
  -h|--help|help)     usage ;;
  *)                  die "Unknown command: $CMD (try '$PROG help')" ;;
esac
